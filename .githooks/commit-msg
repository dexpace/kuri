#
# commit-msg hook: enforce the Angular / Conventional Commits header format.
#
# It validates ONLY the header (the first non-blank, non-comment line) against
#     type(scope)!: subject
# where `type` is one of the allowed types below, `(scope)` and the `!`
# breaking-change marker are optional, exactly one space follows the colon, and
# the subject is non-empty, at most 100 characters (whole header), and does not
# end with a period. The body is never inspected.
#
# Git-generated and rebase autosquash headers are exempt (exit 0 without
# checking): Merge*, Revert*, fixup!*, squash!*, and amend!*.
#
# Portable POSIX sh: relies only on grep, wc and printf. No bash extensions.

COMMIT_MSG_FILE="$1"

# HEADER = first line that is neither blank nor a comment (first non-space char
# is `#`). grep drops blank/whitespace-only and comment lines; `read` keeps only
# the first survivor. Comments are still present here: git strips them after the
# commit-msg hook runs, not before.
HEADER=$(grep -Ev '^[[:space:]]*(#|$)' "$COMMIT_MSG_FILE" | { IFS= read -r line; printf '%s' "$line"; })

# Exemptions: merge/revert commits and rebase autosquash markers are generated
# by git itself, so we never rewrite or gate them.
case "$HEADER" in
    "Merge "* | "Revert "* | "fixup!"* | "squash!"* | "amend!"*)
        exit 0
        ;;
esac

# Allowed header types (lowercase only) and the fully-anchored header grammar.
# Scope charset: lowercase letters, digits, and . _ / - (the `-` is last in the
# class so it is a literal, not a range).
TYPES='feat|fix|docs|test|chore|perf|refactor|ci|build|style|revert|merge'
HEADER_REGEX="^($TYPES)(\([a-z0-9._/-]+\))?!?: [^ ].*$"

LENGTH=$(printf '%s' "$HEADER" | wc -m)

REASON=""
if ! printf '%s\n' "$HEADER" | grep -Eq "$HEADER_REGEX"; then
    REASON="header does not match type(scope)!: subject"
elif [ "$LENGTH" -gt 100 ]; then
    REASON="header is longer than 100 characters ($LENGTH)"
else
    case "$HEADER" in
        *.)
            REASON="subject must not end with a period"
            ;;
        *" ")
            REASON="subject must not end with a space"
            ;;
    esac
fi

if [ -n "$REASON" ]; then
    printf '%s\n' \
        "commit-msg: rejected commit header." \
        "  Reason: $REASON" \
        "" \
        "  Offending header:" \
        "    $HEADER" \
        "" \
        "  Expected format:  type(scope)!: subject" \
        "    - type is required; (scope) and the ! breaking-change marker are optional" \
        "    - exactly one space after the colon; subject is non-empty and must not" \
        "      start or end with a space, must not end with a period, and the whole" \
        "      header must be at most 100 characters" \
        "" \
        "  Allowed types:" \
        "    feat fix docs test chore perf refactor ci build style revert merge" \
        "" \
        "  Scope may contain lowercase letters, digits, and . _ / -" \
        "" \
        "  Examples:" \
        "    feat(parser): support IPv6 zone identifiers" \
        "    fix: reject rootless paths that drop the leading slash" \
        "    docs(readme)!: rename the primary entry point" \
        "" \
        "  Merge, Revert, fixup!, squash! and amend! headers are exempt." >&2
    exit 1
fi

exit 0
